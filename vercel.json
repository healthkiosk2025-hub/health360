{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ],
  "env": {
    "DB_HOST": "@db_host",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password", 
    "DB_DATABASE": "@db_database", 
    "JWT_SECRET": "@jwt_secret",
    "NODEMAILER_USER": "@nodemailer_user",
    "NODEMAILER_PASS": "@nodemailer_pass"
  }
}
